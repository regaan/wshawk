{
  "manifest_version": 3,
  "name": "WSHawk Companion",
  "version": "4.0.0",
  "description": "Capture WebSocket handshakes and sync them into the local WSHawk bridge.",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
